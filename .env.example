# ── SatNOGS Offline Pipeline ──
SATNOGS_API_TOKEN=your_token_here

# ── Docker Compose Services ──
POSTGRES_USER=watchdog
POSTGRES_PASSWORD=watchdog_pass
POSTGRES_DB=watchdog_db

# ── Backend API Config ──
DATABASE_URL=postgresql://watchdog:watchdog_pass@localhost:5432/watchdog_db

# Frontend: Only needed for local development (points to backend).
# In production/VPS, leave this blank as Caddy routes traffic natively.
PUBLIC_API_URL=http://localhost:8000

# ── Cloud VPS Infrastructure ──
MQTT_ALLOW_ANONYMOUS=false
MQTT_USERNAME=edge_station_1
MQTT_PASSWORD=your_secure_password
MQTT_USE_TLS=true

# ── Edge Agent (Ground Station) ──
MQTT_BROKER_URL=vps.yourdomain.com
MQTT_BROKER_PORT=8883
EDGE_LOCAL_BACKUP_PATH=./data/raw/fallback_buffer.csv
EDGE_RETRY_INTERVAL_SECONDS=5
COMPOSE_PROFILES=dev
