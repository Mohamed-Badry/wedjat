{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "allowJs": false,
    "checkJs": false,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "typeRoots": ["./node_modules/@types"],
    "types": ["node", "vite/client"]
  },
  "exclude": ["../node_modules/**", "../../node_modules/**", "../../../node_modules/**"]
}
